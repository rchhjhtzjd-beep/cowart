# Cowart Canvas — Server
COWART_PORT=43218
COWART_HOST=0.0.0.0

# Canvas data directory (default: ./canvas)
# COWART_PROJECT_DIR=/path/to/project
# COWART_CANVAS_DIR=/path/to/canvas/data

# Production mode
# NODE_ENV=production

# tldraw license key (required for production deployment)
# Get one at https://tldraw.dev or contact sales@tldraw.com
VITE_TLDRAW_LICENSE_KEY=

# Agnes AI API Key (for image generation)
# AGNES_API_KEY=sk-xxxxxxxxxxxxxxxx
