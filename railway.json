{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "VITE_TLDRAW_LICENSE_KEY": "${VITE_TLDRAW_LICENSE_KEY}"
    }
  },
  "deploy": {
    "startCommand": "node server/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/api/canvas",
    "env": [
      {
        "key": "PORT",
        "value": "${PORT}"
      }
    ]
  }
}
